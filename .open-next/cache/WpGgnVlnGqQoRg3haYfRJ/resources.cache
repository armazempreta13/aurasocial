/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"bg-background text-foreground min-h-screen flex flex-col font-sans\"><main class=\"min-h-screen bg-[#f7f8fb] text-slate-950\"><div class=\"mx-auto max-w-[1480px] px-6 py-6 sm:px-10 xl:px-12\"><header class=\"flex justify-end rounded-[24px] border border-white/60 bg-white/70 px-5 py-3 backdrop-blur-sm\"><div class=\"flex items-center gap-3\"><a class=\"rounded-full px-4 py-2.5 text-sm font-semibold text-slate-600 transition hover:text-slate-900\" href=\"/?auth=login\">Log in</a><a class=\"rounded-xl bg-[#6f63dd] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#5e53cd]\" href=\"/?auth=signup\">Getting Started</a></div></header><section class=\"mx-auto max-w-6xl px-2 py-10 sm:px-4 lg:py-14\"><div class=\"max-w-3xl\"><p class=\"text-sm font-semibold uppercase tracking-[0.18em] text-primary\">Aura</p><h1 class=\"mt-3 text-4xl font-black tracking-[-0.04em] text-[#2e3277] sm:text-5xl\">Recursos centrais da Aura</h1><p class=\"mt-4 text-lg leading-8 text-slate-600\">Entenda rapidamente como feed inteligente, reputacao e descoberta por interesse funcionam dentro da rede.</p></div><div class=\"mt-10\"><section id=\"features\" class=\"mx-auto max-w-7xl px-5 py-14 sm:px-6 lg:px-8 lg:py-18\"><div class=\"max-w-2xl\"><p class=\"text-sm font-semibold uppercase tracking-[0.18em] text-primary\">Por que Aura</p><h2 class=\"mt-3 text-3xl font-black tracking-[-0.03em] text-slate-950 sm:text-4xl\">A rede social projetada para clareza, contexto e descoberta relevante.</h2></div><div class=\"mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4\"><div class=\"rounded-[26px] border border-slate-200 bg-white p-5 shadow-[0_16px_48px_rgba(15,23,42,0.06)]\"><div class=\"flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-brain-circuit h-5 w-5\" aria-hidden=\"true\"><path d=\"M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z\"></path><path d=\"M9 13a4.5 4.5 0 0 0 3-4\"></path><path d=\"M6.003 5.125A3 3 0 0 0 6.401 6.5\"></path><path d=\"M3.477 10.896a4 4 0 0 1 .585-.396\"></path><path d=\"M6 18a4 4 0 0 1-1.967-.516\"></path><path d=\"M12 13h4\"></path><path d=\"M12 18h6a2 2 0 0 1 2 2v1\"></path><path d=\"M12 8h8\"></path><path d=\"M16 8V5a2 2 0 0 1 2-2\"></path><circle cx=\"16\" cy=\"13\" r=\".5\"></circle><circle cx=\"18\" cy=\"3\" r=\".5\"></circle><circle cx=\"20\" cy=\"21\" r=\".5\"></circle><circle cx=\"20\" cy=\"8\" r=\".5\"></circle></svg></div><h3 class=\"mt-5 text-lg font-bold text-slate-950\">Feed inteligente</h3><p class=\"mt-2 text-sm leading-6 text-slate-600\">O conteúdo sobe por relevância e qualidade, não só por barulho ou volume.</p></div><div class=\"rounded-[26px] border border-slate-200 bg-white p-5 shadow-[0_16px_48px_rgba(15,23,42,0.06)]\"><div class=\"flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-users h-5 w-5\" aria-hidden=\"true\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><path d=\"M16 3.128a4 4 0 0 1 0 7.744\"></path><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle></svg></div><h3 class=\"mt-5 text-lg font-bold text-slate-950\">Comunidades por interesse</h3><p class=\"mt-2 text-sm leading-6 text-slate-600\">Entre em grupos que fazem sentido para seu contexto e descubra pessoas certas.</p></div><div class=\"rounded-[26px] border border-slate-200 bg-white p-5 shadow-[0_16px_48px_rgba(15,23,42,0.06)]\"><div class=\"flex h-12 w-12 items-center justify-cente