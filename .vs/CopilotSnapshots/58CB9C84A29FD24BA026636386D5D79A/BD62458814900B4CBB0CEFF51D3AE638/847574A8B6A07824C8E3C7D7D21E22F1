'use client';

import { FormEvent, useEffect, useMemo, useRef, useState } from 'react';
import { useAppStore } from '@/lib/store';
import {
  Calendar,
  ChevronLeft,
  Info,
  Paperclip,
  Phone,
  Send,
  Smile,
  Trash2,
  Video,
  Check,
  CheckCheck,
} from 'lucide-react';
import { useTranslation } from 'react-i18next';
import { ChatListItem, ChatMessage, groupMessagesByDay } from '@/lib/chat-runtime';
import { TimeAgo } from '@/components/TimeAgo';
import { renderTextWithLinks } from '@/lib/mentions';
import { MentionSuggestions } from '@/components/MentionSuggestions';

interface ChatConversationProps {
  chat: ChatListItem | null;
  messages: ChatMessage[];
  currentUserId: string;
  isTyping: boolean;
  isWindow?: boolean;
  value: string;
  onChange: (value: string) => void;
  onBack?: () => void;
  onSend: () => void;
  onUpload: (file: File) => void;
}

export function ChatConversation({
  chat,
  messages,
  currentUserId,
  isTyping,
  isWindow = false,
  value,
  onChange,
  onBack,
  onSend,
  onUpload,
}: ChatConversationProps) {
  const { t } = useTranslation('common');
  const groups = useMemo(() => groupMessagesByDay(messages), [messages]);
  const messagesEndRef = useRef<HTMLDivElement>(null);
  const fileInputRef = useRef<HTMLInputElement>(null);
  const inputRef = useRef<HTMLInputElement>(null);
  const [mentionSearch, setMentionSearch] = useState<{ text: string, index: number } | null>(null);

  useEffect(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth', block: 'end' });
  }, [messages, isTyping]);

  const startCall = useAppStore((state) => state.startCall);

  if (!chat) {
    return (
      <div className="flex h-full items-center justify-center bg-white p-8 text-center">
        <div className="max-w-sm">
          <div className="mx-auto mb-6 flex h-20 w-20 items-center justify-center rounded-[28px] border border-slate-100 bg-slate-50 text-blue-600 shadow-sm">
            <Send className="h-9 w-9" />
          </div>
          <h2 className="text-2xl font-black tracking-tight text-slate-900">
            {t('messages_page.select_chat', 'Selecione uma conversa para começar a digitar.')}
          </h2>
          <p className="mt-2 text-sm font-medium leading-relaxed text-slate-500">
            {t('messages_page.workspace_desc', 'Suas mensagens ficam acessíveis em qualquer tela, sem interromper o que você está fazendo.')}
          </p>
        </div>
      </div>
    );
  }

  const handleSubmit = (event: FormEvent) => {
    event.preventDefault();
    if (value.trim()) onSend();
  };

  return (
    <div className="flex h-full flex-col bg-white">
      {!isWindow && (
        <header className={`flex shrink-0 items-center justify-between border-b border-slate-100 bg-white/85 backdrop-blur-xl ${isWindow ? 'px-4 py-3' : 'h-[84px] px-8'}`}>
          <div className="flex items-center gap-3">
            {onBack && (
              <button
                onClick={onBack}
                className="rounded-full p-2.5 text-slate-500 transition-colors hover:bg-slate-100 hover:text-slate-900"
              >
                <ChevronLeft size={18} />
              </button>
            )}
            <img
              src={chat.otherUser.photoURL || `https://ui-avatars.com/api/?name=${encodeURIComponent(chat.otherUser.displayName)}`}
              className={`${isWindow ? 'h-10 w-10 rounded-2xl' : 'h-12 w-12 rounded-[22px]'} object-cover shadow-sm`}
              alt={chat.otherUser.displayName}
            />
            <div className="min-w-0">
              <h2 className={`${isWindow ? 'text-[15px]' : 'text-[17px]'} truncate font-black tracking-tight text-slate-900`}>
                {chat.otherUser.displayName}
              </h2>
              <span className="text-[10px] font-black uppercase tracking-[0.2em] text-green-600">
                {isTyping ? t('messages_page.typing', 'Escrevendo...') : t('messages_page.active_now', 'Ativo agora')}
              </span>
            </div>
          </div>

          <div className={`flex items-center ${isWindow ? 'gap-1.5' : 'gap-2'}`}>
            <button
              title={t('messages_page.audio_call', 'Ligação de áudio')}
              onClick={() => startCall?.(chat.otherUser.uid, chat.otherUser.displayName, 'audio', chat.otherUser.photoURL)}
              className={`${isWindow ? 'h-9 w-9' : 'h-11 w-11'} flex items-center justify-center rounded-full bg-green-50 text-green-600 transition-all hover:bg-green-100 active:scale-95`}
            >
              <Phone size={isWindow ? 16 : 20} />
            </button>
            <button
              title={t('messages_page.video_call', 'Ligação de vídeo')}
              onClick={() => startCall?.(chat.otherUser.uid, chat.otherUser.displayName, 'video', chat.otherUser.photoURL)}
              className={`${isWindow ? 'h-9 w-9' : 'h-11 w-11'} flex items-center justify-center rounded-full bg-blue-50 text-blue-600 transition-all hover:bg-blue-100 active:scale-95`}
            >
              <Video size={isWindow ? 16 : 20} />
            </button>
            <button className="rounded-full p-3 text-slate-400 transition-all hover:bg-slate-50">
              <Info size={22} />
            </button>
            <button className="rounded-full p-3 text-slate-400 transition-all hover:bg-slate-50">
              <Trash2 size={22} />
            </button>
          </div>
        </header>
      )}

      <div className={`scrollbar-hide flex-1 overflow-y-auto ${isWindow ? 'space-y-6 px-4 py-5' : 'space-y-10 bg-[#f8fafc]/50 px-10 py-12'}`}>
        {groups.map(([date, dayMessages]) => (
          <div key={date} className={isWindow ? 'space-y-4' : 'space-y-8'}>
            <div className={`flex items-center ${isWindow ? 'gap-3' : 'gap-6'}`}>
              <div className="h-px flex-1 bg-slate-200" />
              <span className="flex items-center gap-2 text-[10px] font-bold uppercase tracking-[0.25em] text-slate-400">
                <Calendar size={12} /> {date}
              </span>
              <div className="h-px flex-1 bg-slate-200" />
            </div>

            {dayMessages.map((message) => {
              const isMe = message.senderId === currentUserId;
              return (
                <div
                  key={message.id}
                  className={`group relative flex max-w-[84%] flex-col ${isMe ? 'ml-auto items-end' : 'items-start'}`}
                >
                  {message.type === 'image' ? (
                    <div className={`rounded-[28px] p-1.5 shadow-lg ${isMe ? 'bg-blue-600 shadow-blue-600/20' : 'bg-white shadow-slate-200'}`}>
                      <img
                        src={message.attachmentUrl}
                        className={`${isWindow ? 'max-h-[220px]' : 'max-h-[400px]'} max-w-full rounded-[22px] object-cover`}
                        alt={t('messages_page.shared_image', 'Imagem compartilhada')}
                      />
                    </div>
                  ) : (
                    <div
                      className={`ring-black/5 shadow-sm ring-1 ${isWindow ? 'px-4 py-3 text-[14px]' : 'px-6 py-4 text-[15px]'} rounded-[28px] font-medium leading-relaxed ${
                        isMe
                          ? 'rounded-br-none bg-gradient-to-br from-blue-600 to-blue-700 text-white shadow-blue-600/20'
                          : 'rounded-bl-none bg-white text-slate-800'
                      }`}
                    >
                      {renderTextWithLinks(message.text, { linkClassName: isMe ? 'text-white/90 font-bold underline' : 'text-blue-600 font-bold hover:underline' })}
                    </div>
                  )}

                  <div className={`mt-2 flex items-center gap-2 px-2 ${isMe ? 'flex-row-reverse' : ''}`}>
                    <span className="text-[10px] font-bold uppercase tracking-tight text-slate-400">
                      <TimeAgo date={new Date(message.createdAt)} />
                    </span>
                    {isMe && (message.read ? <CheckCheck size={14} className="text-blue-600" /> : <Check size={14} className="text-slate-300" />)}
                  </div>
                </div>
              );
            })}
          </div>
        ))}

        {isTyping && (
          <div className="flex items-center gap-2 pl-2">
            <div className="flex items-center gap-1 rounded-full bg-white px-4 py-2 shadow-sm ring-1 ring-slate-100">
              <span className="h-2 w-2 animate-bounce rounded-full bg-slate-300 [animation-delay:-0.2s]" />
              <span className="h-2 w-2 animate-bounce rounded-full bg-slate-300 [animation-delay:-0.1s]" />
              <span className="h-2 w-2 animate-bounce rounded-full bg-slate-300" />
            </div>
          </div>
        )}

        <div ref={messagesEndRef} />
      </div>

      <footer className={`shrink-0 border-t border-slate-100 bg-white ${isWindow ? 'p-3' : 'p-8'}`}>
        <input
          type="file"
          ref={fileInputRef}
          onChange={(event) => {
            const file = event.target.files?.[0];
            if (!file) return;
            onUpload(file);
            event.currentTarget.value = '';
          }}
          accept="image/*"
          className="hidden"
        />

        <div className={`flex items-center ${isWindow ? 'gap-2' : 'gap-4'}`}>
          <button
            onClick={() => fileInputRef.current?.click()}
            className={`${isWindow ? 'h-10 w-10 rounded-2xl' : 'h-14 w-14 rounded-[22px]'} flex items-center justify-center bg-slate-100 text-slate-500 transition-all hover:bg-slate-200`}
          >
            <Paperclip size={isWindow ? 18 : 22} />
          </button>

          <div className={`flex flex-1 items-center rounded-[28px] bg-slate-100 transition-all focus-within:bg-white focus-within:ring-8 focus-within:ring-blue-600/5 ${isWindow ? 'px-4' : 'px-6'} relative`}>
            <input
              ref={inputRef}
              value={value}
              onChange={(event) => {
                const newValue = event.target.value;
                const cursor = event.target.selectionStart || 0;
                onChange(newValue);

                const textBeforeCursor = newValue.substring(0, cursor);
                const lastAt = textBeforeCursor.lastIndexOf('@');
                
                if (lastAt !== -1) {
                  const textAfterAt = textBeforeCursor.substring(lastAt + 1);
                  if (!textAfterAt.includes(' ') && !textAfterAt.includes('\n')) {
                    setMentionSearch({ text: textAfterAt, index: lastAt });
                    return;
                  }
                }
                setMentionSearch(null);
              }}
              onKeyDown={(e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                  if (mentionSearch) {
                    // We could let the mention suggestion handle this, but for now just prevent sending
                    return;
                  }
                  e.preventDefault();
                  onSend();
                }
                if (e.key === 'Escape') setMentionSearch(null);
              }}
              placeholder={t('messages_page.composer_placeholder', 'Digite uma mensagem...')}
              className={`flex-1 bg-transparent font-medium text-slate-900 focus:outline-none ${isWindow ? 'py-3 text-[14px]' : 'py-5 text-[16px]'}`}
            />
            {mentionSearch && (
              <div className="absolute bottom-full left-0 mb-4 z-50">
                <MentionSuggestions 
                  searchText={mentionSearch.text} 
                  onSelect={(user) => {
                    const before = value.substring(0, mentionSearch.index);
                    const after = value.substring(inputRef.current?.selectionStart || 0);
                    const newValue = `${before}@${user.username} ${after}`;
                    onChange(newValue);
                    setMentionSearch(null);
                    setTimeout(() => {
                      inputRef.current?.focus();
                      const newCursor = mentionSearch.index + user.username.length + 2;
                      inputRef.current?.setSelectionRange(newCursor, newCursor);
                    }, 0);
                  }} 
                  onClose={() => setMentionSearch(null)} 
                />
              </div>
            )}
            <button type="button" className="p-2 text-slate-400 transition-colors hover:text-blue-600">
              <Smile size={isWindow ? 20 : 24} />
            </button>
          </div>

          <button
            onClick={onSend}
            className={`${isWindow ? 'h-10 w-10' : 'h-14 w-14'} flex items-center justify-center rounded-full bg-blue-600 text-white shadow-xl shadow-blue-600/30 transition-all hover:scale-105 active:scale-95`}
          >
            <Send size={isWindow ? 18 : 22} className="relative -right-0.5" />
          </button>
        </div>
      </footer>
    </div>
  );
}
